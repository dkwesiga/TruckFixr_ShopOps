# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma / Postgres (Supabase connection strings)
# Use the "Transaction" pooler URL from Supabase dashboard → Settings → Database → Connection pooling
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-xx-east-1.pooler.supabase.com:6543/postgres
# Direct (non-pooled) connection for Prisma migrations
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-xx-east-1.pooler.supabase.com:5432/postgres

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENABLE_DEMO_AUTH=true

# AI Capture (Milestone 4) — optional; capture UI hides itself when unset
# Groq: voice transcription (whisper-large-v3-turbo)
GROQ_API_KEY=your-groq-api-key
# OpenRouter: text + image extraction (free-tier, vision-capable model)
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional overrides (sensible defaults baked in):
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# OPENROUTER_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

# Email delivery (Milestone 6) — optional; send buttons hide when unset
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# From address — use a verified domain in production (sandbox default works for testing)
# RESEND_FROM=TruckFixr ShopOps <onboarding@resend.dev>
