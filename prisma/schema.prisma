generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Plan {
  free
  standard
}

enum UserRole {
  owner
}

enum ItemType {
  labour
  part
  fee
}

enum EstimateStatus {
  draft
  sent
  approved
  declined
  converted
  cancelled
}

enum WorkOrderStatus {
  draft
  approved
  in_progress
  done
  invoiced
}

enum InvoiceStatus {
  draft
  sent
  paid
  partially_paid
  overdue
  void
}

enum PaymentMethod {
  cash
  debit
  credit_card
  e_transfer
  cheque
  stripe
  other
}

enum AttachmentType {
  photo
  voice_note
  vendor_invoice
  other
}

enum AiCaptureType {
  transcription
  text_extraction
  image_extraction
}

enum AiCaptureStatus {
  success
  failure
  rate_limited
  fallback_triggered
}

// ---------------------------------------------------------------------------
// Company — one row per shop; all shop-specific tables FK to this
// ---------------------------------------------------------------------------

model Company {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  province          String   @default("ON")
  address           String?
  phone             String?
  email             String?
  defaultLabourRate Decimal  @db.Decimal(10, 2)
  plan              Plan     @default(free)
  monthlyDocCount   Int      @default(0)
  monthlyDocResetAt DateTime @default(now())
  pilotFounderRate  Boolean  @default(false)
  logoUrl           String?
  numberingPrefix   String?
  termsText         String?
  warrantyText      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users            User[]
  customers        Customer[]
  vehicles         Vehicle[]
  items            Item[]
  labourTemplates  LabourTemplate[]
  estimates        Estimate[]
  workOrders       WorkOrder[]
  invoices         Invoice[]
  payments         Payment[]
  attachments      Attachment[]
  taxRates         TaxRate[]
  exportLogs       ExportLog[]
  aiCaptureLogs    AiCaptureLog[]
  aiCorrectionLogs AiCorrectionLog[]
  feedback         Feedback[]

  @@map("companies")
}

// ---------------------------------------------------------------------------
// User — mirrors Supabase auth.users; id = Supabase auth UUID
// ---------------------------------------------------------------------------

model User {
  id        String   @id @db.Uuid
  companyId String   @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id])
  email     String
  role      UserRole @default(owner)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ---------------------------------------------------------------------------
// Customer
// ---------------------------------------------------------------------------

model Customer {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @db.Uuid
  company        Company  @relation(fields: [companyId], references: [id])
  name           String
  companyName    String?
  contactPerson  String?
  phone          String?
  email          String?
  billingAddress String?
  serviceAddress String?
  paymentTerms   String?
  taxExempt      Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicles         Vehicle[]
  estimates        Estimate[]
  invoices         Invoice[]
  payments         Payment[]
  aiCorrectionLogs AiCorrectionLog[]

  @@map("customers")
}

// ---------------------------------------------------------------------------
// Vehicle
// ---------------------------------------------------------------------------

model Vehicle {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @db.Uuid
  company      Company  @relation(fields: [companyId], references: [id])
  customerId   String   @db.Uuid
  customer     Customer @relation(fields: [customerId], references: [id])
  unitNumber   String?
  vin          String?
  plate        String?
  year         Int?
  make         String?
  model        String?
  engine       String?
  transmission String?
  odometer     Int?
  engineHours  Int?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  estimates        Estimate[]
  workOrders       WorkOrder[]
  invoices         Invoice[]
  aiCorrectionLogs AiCorrectionLog[]

  @@map("vehicles")
}

// ---------------------------------------------------------------------------
// Item — both labour and parts; fitment columns only used when type = part
// ---------------------------------------------------------------------------

model Item {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @db.Uuid
  company         Company  @relation(fields: [companyId], references: [id])
  type            ItemType
  name            String
  description     String?
  partNumber      String?
  cost            Decimal? @db.Decimal(10, 2)
  sellPrice       Decimal? @db.Decimal(10, 2)
  defaultRate     Decimal? @db.Decimal(10, 2)
  defaultTime     Decimal? @db.Decimal(6, 2)
  taxable         Boolean  @default(true)
  qtyOnHand       Decimal? @db.Decimal(10, 2)
  fitmentMake     String?
  fitmentModel    String?
  fitmentYearFrom Int?
  fitmentYearTo   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  estimateLines EstimateLine[]
  invoiceLines  InvoiceLine[]

  @@map("items")
}

// ---------------------------------------------------------------------------
// LabourTemplate — pre-built job templates (5-10 seeded per new company)
// ---------------------------------------------------------------------------

model LabourTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @db.Uuid
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  defaultTime Decimal  @db.Decimal(6, 2)
  defaultRate Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("labour_templates")
}

// ---------------------------------------------------------------------------
// Estimate
// ---------------------------------------------------------------------------

model Estimate {
  id                     String         @id @default(uuid()) @db.Uuid
  companyId              String         @db.Uuid
  company                Company        @relation(fields: [companyId], references: [id])
  estimateNumber         String
  customerId             String         @db.Uuid
  customer               Customer       @relation(fields: [customerId], references: [id])
  vehicleId              String?        @db.Uuid
  vehicle                Vehicle?       @relation(fields: [vehicleId], references: [id])
  status                 EstimateStatus @default(draft)
  complaint              String?
  recommendedWork        String?
  customerNotes          String?
  internalNotes          String?
  subtotal               Decimal        @default(0) @db.Decimal(10, 2)
  taxAmount              Decimal        @default(0) @db.Decimal(10, 2)
  total                  Decimal        @default(0) @db.Decimal(10, 2)
  expiryDate             DateTime?
  approvalToken          String?        @unique
  approvalTokenExpiresAt DateTime?
  approvedAt             DateTime?
  declinedAt             DateTime?
  sentAt                 DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  lines         EstimateLine[]
  workOrder     WorkOrder?
  invoice       Invoice?
  attachments   Attachment[]
  aiCaptureLogs AiCaptureLog[]

  @@map("estimates")
}

// ---------------------------------------------------------------------------
// EstimateLine
// ---------------------------------------------------------------------------

model EstimateLine {
  id           String   @id @default(uuid()) @db.Uuid
  estimateId   String   @db.Uuid
  estimate     Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  itemId       String?  @db.Uuid
  item         Item?    @relation(fields: [itemId], references: [id])
  type         ItemType
  description  String
  quantity     Decimal  @db.Decimal(10, 3)
  unitPrice    Decimal  @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  taxable      Boolean  @default(true)
  aiSuggested  Boolean  @default(false)
  aiConfidence Decimal? @db.Decimal(4, 3)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("estimate_lines")
}

// ---------------------------------------------------------------------------
// WorkOrder
// ---------------------------------------------------------------------------

model WorkOrder {
  id         String          @id @default(uuid()) @db.Uuid
  companyId  String          @db.Uuid
  company    Company         @relation(fields: [companyId], references: [id])
  estimateId String          @unique @db.Uuid
  estimate   Estimate        @relation(fields: [estimateId], references: [id])
  vehicleId  String?         @db.Uuid
  vehicle    Vehicle?        @relation(fields: [vehicleId], references: [id])
  status     WorkOrderStatus @default(approved)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  invoice     Invoice?
  attachments Attachment[]

  @@map("work_orders")
}

// ---------------------------------------------------------------------------
// Invoice
// ---------------------------------------------------------------------------

model Invoice {
  id                   String        @id @default(uuid()) @db.Uuid
  companyId            String        @db.Uuid
  company              Company       @relation(fields: [companyId], references: [id])
  invoiceNumber        String
  customerId           String        @db.Uuid
  customer             Customer      @relation(fields: [customerId], references: [id])
  vehicleId            String?       @db.Uuid
  vehicle              Vehicle?      @relation(fields: [vehicleId], references: [id])
  estimateId           String?       @unique @db.Uuid
  estimate             Estimate?     @relation(fields: [estimateId], references: [id])
  workOrderId          String?       @unique @db.Uuid
  workOrder            WorkOrder?    @relation(fields: [workOrderId], references: [id])
  status               InvoiceStatus @default(draft)
  invoiceDate          DateTime      @default(now())
  dueDate              DateTime?
  paymentTerms         String?
  subtotal             Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount            Decimal       @default(0) @db.Decimal(10, 2)
  total                Decimal       @default(0) @db.Decimal(10, 2)
  amountPaid           Decimal       @default(0) @db.Decimal(10, 2)
  balanceDue           Decimal       @default(0) @db.Decimal(10, 2)
  hasVariance          Boolean       @default(false)
  customerNotes        String?
  internalNotes        String?
  stripePaymentLinkId  String?
  stripePaymentLinkUrl String?
  sentAt               DateTime?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  lines         InvoiceLine[]
  payments      Payment[]
  attachments   Attachment[]
  exportLogs    ExportLog[]
  aiCaptureLogs AiCaptureLog[]

  @@map("invoices")
}

// ---------------------------------------------------------------------------
// InvoiceLine
// ---------------------------------------------------------------------------

model InvoiceLine {
  id           String   @id @default(uuid()) @db.Uuid
  invoiceId    String   @db.Uuid
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemId       String?  @db.Uuid
  item         Item?    @relation(fields: [itemId], references: [id])
  type         ItemType
  description  String
  quantity     Decimal  @db.Decimal(10, 3)
  unitPrice    Decimal  @db.Decimal(10, 2)
  cost         Decimal? @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  taxable      Boolean  @default(true)
  aiSuggested  Boolean  @default(false)
  aiConfidence Decimal? @db.Decimal(4, 3)
  isVariance   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("invoice_lines")
}

// ---------------------------------------------------------------------------
// Payment
// ---------------------------------------------------------------------------

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  companyId             String        @db.Uuid
  company               Company       @relation(fields: [companyId], references: [id])
  invoiceId             String        @db.Uuid
  invoice               Invoice       @relation(fields: [invoiceId], references: [id])
  customerId            String        @db.Uuid
  customer              Customer      @relation(fields: [customerId], references: [id])
  date                  DateTime      @default(now())
  amount                Decimal       @db.Decimal(10, 2)
  method                PaymentMethod
  referenceNumber       String?
  notes                 String?
  stripePaymentIntentId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@map("payments")
}

// ---------------------------------------------------------------------------
// Attachment — photos, voice notes, vendor invoice images (stored in Supabase Storage)
// ---------------------------------------------------------------------------

model Attachment {
  id          String         @id @default(uuid()) @db.Uuid
  companyId   String         @db.Uuid
  company     Company        @relation(fields: [companyId], references: [id])
  estimateId  String?        @db.Uuid
  estimate    Estimate?      @relation(fields: [estimateId], references: [id])
  workOrderId String?        @db.Uuid
  workOrder   WorkOrder?     @relation(fields: [workOrderId], references: [id])
  invoiceId   String?        @db.Uuid
  invoice     Invoice?       @relation(fields: [invoiceId], references: [id])
  type        AttachmentType
  storageKey  String
  fileName    String?
  mimeType    String?
  sizeBytes   Int?
  notes       String?
  createdAt   DateTime       @default(now())

  @@map("attachments")
}

// ---------------------------------------------------------------------------
// TaxRate
// ---------------------------------------------------------------------------

model TaxRate {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  rate      Decimal  @db.Decimal(6, 4)
  province  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tax_rates")
}

// ---------------------------------------------------------------------------
// ExportLog
// ---------------------------------------------------------------------------

model ExportLog {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @db.Uuid
  company    Company  @relation(fields: [companyId], references: [id])
  invoiceId  String?  @db.Uuid
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  exportType String
  exportedAt DateTime @default(now())
  fileKey    String?

  @@map("export_logs")
}

// ---------------------------------------------------------------------------
// AiCaptureLog — stub for Milestone 4; tracks every AI call outcome
// ---------------------------------------------------------------------------

model AiCaptureLog {
  id           String          @id @default(uuid()) @db.Uuid
  companyId    String          @db.Uuid
  company      Company         @relation(fields: [companyId], references: [id])
  estimateId   String?         @db.Uuid
  estimate     Estimate?       @relation(fields: [estimateId], references: [id])
  invoiceId    String?         @db.Uuid
  invoice      Invoice?        @relation(fields: [invoiceId], references: [id])
  captureType  AiCaptureType
  provider     String
  model        String
  status       AiCaptureStatus
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int?
  errorMessage String?
  createdAt    DateTime        @default(now())

  @@map("ai_capture_logs")
}

// ---------------------------------------------------------------------------
// AiCorrectionLog — stub for Milestone 4; stores user edits of AI suggestions
// ---------------------------------------------------------------------------

model AiCorrectionLog {
  id             String        @id @default(uuid()) @db.Uuid
  companyId      String        @db.Uuid
  company        Company       @relation(fields: [companyId], references: [id])
  customerId     String?       @db.Uuid
  customer       Customer?     @relation(fields: [customerId], references: [id])
  vehicleId      String?       @db.Uuid
  vehicle        Vehicle?      @relation(fields: [vehicleId], references: [id])
  itemId         String?       @db.Uuid
  fieldName      String
  originalValue  String?
  correctedValue String
  captureType    AiCaptureType
  createdAt      DateTime      @default(now())

  @@map("ai_correction_logs")
}

// ---------------------------------------------------------------------------
// Feedback — low-friction "Something off? Tell us" submissions (Section 6.5)
// ---------------------------------------------------------------------------

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?  @db.Uuid
  message   String
  context   String?
  createdAt DateTime @default(now())

  @@map("feedback")
}
