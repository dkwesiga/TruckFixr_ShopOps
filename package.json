{
  "name": "shopops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/next/dist/bin/next dev",
    "build": "npm run typecheck && npm run lint && node --use-system-ca ./node_modules/next/dist/bin/next build",
    "start": "node --use-system-ca ./node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "typecheck": "node --use-system-ca ./node_modules/next/dist/bin/next typegen && tsc --noEmit --pretty false --incremental false",
    "db:generate": "node node_modules/prisma/build/index.js generate",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:push": "node node_modules/prisma/build/index.js db push",
    "db:seed": "node node_modules/prisma/build/index.js db seed",
    "db:studio": "node node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^8.55.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.108.2",
    "next": "15.5.8",
    "pg": "^8.21.0",
    "prisma": "^6.19.3",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
